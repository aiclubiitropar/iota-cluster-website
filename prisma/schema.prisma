generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TeamMember {
  id           String   @id @default(uuid())
  name         String
  position     String
  imageUrl     String?
  linkedinUrl  String?
  githubUrl    String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  imageUrl    String?
  githubUrl   String?
  liveUrl     String?
  tags        String   // comma separated or JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Handle {
  id        String   @id @default(uuid())
  platform  String
  url       String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id           String   @id @default(uuid())
  title        String
  imageUrl     String
  createdAt    DateTime @default(now())
}
